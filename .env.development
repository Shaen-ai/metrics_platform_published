# Used by `next dev` only.
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# Default tenant. The seeded `demo` user usually has no custom logo (you will see /logo.png).
# To preview your storefront branding locally, copy this file to `.env.local` and set:
# NEXT_PUBLIC_ADMIN_SLUG=<your-published-slug>
NEXT_PUBLIC_ADMIN_SLUG=demo
