# GA4 Measurement ID (see `.env.production`). Omitted in dev so `next dev` does not load Google tag.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# AI API Configuration
# You can use either OpenAI API or Cursor's API

# Option 1: OpenAI API (recommended)
OPENAI_API_KEY=your_openai_api_key_here
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini
# Laravel uses this model for AI Room Planner intent parsing.
PLANNER_INTENT_MODEL=gpt-4o-mini

# Option 2: Cursor API (if available)
# CURSOR_API_KEY=your_cursor_api_key_here
# AI_API_URL=https://api.cursor.com/v1/chat/completions
# AI_MODEL=cursor-model-name

# Note: AI Room Planner generation requires Laravel to have an AI API key.

# Laravel API (same origin as metrics_platform admin).
LARAVEL_API_URL=http://127.0.0.1:8000/api
# Browser API base used by the AI Room Planner form.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api
# Tenant/admin slug for this published deployment. Localhost falls back to `demo` when unset.
# The seeded demo account often has logo=null — set this to your own slug to see your uploaded logo.
NEXT_PUBLIC_ADMIN_SLUG=demo
# Must match backend .env INTERNAL_API_KEY so server routes can meter usage securely.
INTERNAL_API_KEY=

# Footer “Contact” mailto destination (defaults to support@tunzone.com).
# NEXT_PUBLIC_CONTACT_SUPPORT_EMAIL=

# Committed env: see .env.production (used by `next build`) and .env.development (`next dev`).
# `.env.local` overrides these; it should not exist on the deploy server.
